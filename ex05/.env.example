# ===================================================
# ex05 RAG Q&A 엔진 환경 변수 설정 파일
# cp .env.example .env 후 값을 입력하세요
# ===================================================

# LLM 제공자 선택: ollama | openai | vllm
LLM_PROVIDER=ollama

# --- Ollama 설정 (기본값) ---
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=deepseek-r1:8b

# --- OpenAI 설정 (선택) ---
# LLM_PROVIDER=openai
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini

# --- 임베딩 모델 ---
EMBEDDING_MODEL=jhgan/ko-sroberta-multitask

# --- ChromaDB 설정 ---
# 없으면 data/docs/ 원본 문서에서 자동 구축
# 이전 버전(ex04) 결과를 직접 사용하려면: ../ex04/data/chroma_db
CHROMA_PERSIST_DIR=./data/chroma_db
CHROMA_COLLECTION_NAME=metacoding_documents

# --- FastAPI 서버 설정 ---
FASTAPI_HOST=0.0.0.0
FASTAPI_PORT=8000

# --- 세션 설정 ---
# 세션 만료 시간 (초)
SESSION_TTL_SECONDS=3600
# 대화 히스토리 최근 N턴 유지
CONVERSATION_WINDOW_SIZE=5

# --- RAG 검색 설정 ---
# 검색할 상위 문서 개수
RETRIEVER_TOP_K=5
