# ex06 환경 변수 템플릿
# 복사: cp .env.example .env
# 실제 키를 입력하세요 (이 파일을 Git에 커밋하지 마세요)

# ============================================================
# LLM 설정 (ollama 또는 openai 중 하나 선택)
# ============================================================

# LLM 공급자: "ollama" (로컬, 기본값) 또는 "openai"
LLM_PROVIDER=ollama

# Ollama 설정 (로컬 LLM 사용 시)
# ex06은 Tool Calling이 필요하므로 llama3.1:8b를 사용합니다
# (deepseek-r1:8b는 Tool Calling 미지원)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b

# OpenAI 설정 (OpenAI 사용 시)
OPENAI_API_KEY=sk-your-api-key-here
OPENAI_MODEL=gpt-4o-mini

# ============================================================
# PostgreSQL 설정 (필수 — docker compose up -d 로 실행)
# ============================================================

POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=rag_db
POSTGRES_USER=rag_user
POSTGRES_PASSWORD=rag_password

# ============================================================
# ChromaDB 설정
# 없으면 data/docs/ 원본 문서에서 키워드 검색으로 동작
# ex05 결과를 직접 사용하려면: ../ex05/data/chroma_db
# ============================================================

CHROMA_PERSIST_DIR=./data/chroma_db
CHROMA_COLLECTION_NAME=metacoding_documents
