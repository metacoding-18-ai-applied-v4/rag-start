# =====================================================================
# ex04 VectorDB 구축 — 환경 변수 템플릿
# 사용 방법: cp .env.example .env → 값 수정 후 저장
# =====================================================================

# --- 임베딩 모델 ---
# HuggingFace 모델 ID (최초 실행 시 자동 다운로드, 약 400MB)
EMBEDDING_MODEL=jhgan/ko-sroberta-multitask

# --- ChromaDB 설정 ---
# ChromaDB 저장 경로 (자동 생성됨)
CHROMA_PERSIST_DIR=./data/chroma_db

# ChromaDB 컬렉션명
CHROMA_COLLECTION_NAME=metacoding_documents

# --- 문서 경로 ---
# 파싱할 문서가 저장된 디렉토리 (PDF/DOCX/XLSX)
DOCS_DIR=./data/docs
