# ex08 RAG 튜닝 — 환경 변수 템플릿
# 사용 방법: cp .env.example .env 후 값을 채우십시오.

# ============================================================
# LLM 설정 (ollama 또는 openai 중 하나 선택)
# ============================================================

LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b

# OpenAI 설정 (OpenAI 사용 시)
OPENAI_API_KEY=sk-your-api-key-here
OPENAI_MODEL=gpt-4o-mini

# ============================================================
# PostgreSQL 설정 (선택 — 없으면 인메모리 모드로 동작)
# ============================================================

POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=rag_db
POSTGRES_USER=rag_user
POSTGRES_PASSWORD=rag_password

# ============================================================
# ChromaDB 설정
# ============================================================

CHROMA_PERSIST_DIR=./data/chroma_db
CHROMA_COLLECTION_NAME=metacoding_documents

# ============================================================
# 임베딩 모델 설정
# ============================================================
EMBEDDING_MODEL=jhgan/ko-sroberta-multitask

# ============================================================
# 응답 캐시 설정
# ============================================================
CACHE_TTL=3600
CACHE_MAX_SIZE=1000

# ============================================================
# 임베딩 캐시 설정
# ============================================================
EMBEDDING_CACHE_DIR=./outputs/embedding_cache

# ============================================================
# 로깅 설정
# ============================================================
LOG_LEVEL=INFO
USE_JSON_LOG=false
LOG_FILE=

# ============================================================
# Langfuse 모니터링 설정 (선택)
# ============================================================
# LANGFUSE_PUBLIC_KEY=pk-lf-...
# LANGFUSE_SECRET_KEY=sk-lf-...
# LANGFUSE_HOST=https://cloud.langfuse.com

# ============================================================
# ex08 튜닝 설정
# ============================================================
# 샘플 데이터 사용 (true: 내장 데이터, false: ChromaDB 필요)
USE_SAMPLE_DATA=true

# RAGAS 평가 사용 (true: RAGAS 메트릭 포함, false: 기본 메트릭만)
USE_RAGAS=false

# 실험 결과 출력 디렉토리
EXPERIMENT_OUTPUT_DIR=./outputs/tuning_logs
