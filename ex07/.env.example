# ex07 LangChain 연결 — 환경 변수 템플릿
# 사용 방법: cp .env.example .env 후 값을 채우십시오.

# ============================================================
# LLM 설정 (ollama 또는 openai 중 하나 선택)
# ============================================================

# LLM 공급자: "ollama" (로컬, 기본값) 또는 "openai"
LLM_PROVIDER=ollama

# Ollama 설정 (로컬 LLM 사용 시)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b

# OpenAI 설정 (OpenAI 사용 시)
OPENAI_API_KEY=sk-your-api-key-here
OPENAI_MODEL=gpt-4o-mini

# ============================================================
# PostgreSQL 설정 (선택 — 없으면 인메모리 모드로 동작)
# ============================================================

POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=rag_db
POSTGRES_USER=rag_user
POSTGRES_PASSWORD=rag_password

# ============================================================
# ChromaDB 설정
# 없으면 data/docs/ 원본 문서에서 키워드 검색으로 동작
# 기존 VectorDB 결과를 직접 사용하려면: ../VectorDB_구축/data/chroma_db
# ============================================================

CHROMA_PERSIST_DIR=./data/chroma_db
CHROMA_COLLECTION_NAME=metacoding_documents

# ============================================================
# 임베딩 모델 설정
# ============================================================
EMBEDDING_MODEL=jhgan/ko-sroberta-multitask

# ============================================================
# 응답 캐시 설정 (ex07 추가)
# ============================================================
CACHE_TTL=3600
CACHE_MAX_SIZE=1000

# ============================================================
# 임베딩 캐시 설정 (ex07 추가)
# ============================================================
EMBEDDING_CACHE_DIR=./outputs/embedding_cache

# ============================================================
# 로깅 설정 (ex07 추가)
# ============================================================
# DEBUG, INFO, WARNING, ERROR, CRITICAL 중 선택
LOG_LEVEL=INFO
# true로 설정하면 JSON 형식으로 로그를 출력합니다.
USE_JSON_LOG=false
# 비워두면 콘솔에만 출력합니다. 파일 경로를 입력하면 파일에도 저장됩니다.
LOG_FILE=

# ============================================================
# Langfuse 모니터링 설정 (선택, ex07 추가)
# ============================================================
# Langfuse 설치: pip install langfuse
# 키 미설정 시 자동으로 모니터링이 비활성화됩니다.
# LANGFUSE_PUBLIC_KEY=pk-lf-...
# LANGFUSE_SECRET_KEY=sk-lf-...
# LANGFUSE_HOST=https://cloud.langfuse.com
