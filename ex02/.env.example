# ============================================================
# ex02 환경 변수 예시 파일
# 사용 방법: cp .env.example .env
# ============================================================

# PostgreSQL 연결 정보 (docker-compose 기본값과 동일)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=metacoding_db
POSTGRES_USER=metacoding
POSTGRES_PASSWORD=metacoding_pass

# FastAPI 서버 설정
FASTAPI_HOST=0.0.0.0
FASTAPI_PORT=8000
